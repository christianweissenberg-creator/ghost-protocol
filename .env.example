# ============================================================
# Ghost Protocol — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual API keys.
#   cp .env.example .env
# NEVER commit .env to Git!
# ============================================================

# ── LLM (Pflicht) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database (Pflicht) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key    # Service Role Key, NOT Anon Key!

# ── Search (Pflicht für ORACLE/RESEARCHER) ─────────────────
SERPER_API_KEY=your-serper-key-here             # serper.dev — €5/Mo

# ── Embeddings (eins davon für RAG Knowledge Base) ─────────
VOYAGE_API_KEY=                                 # Voyage AI (Anthropic Partner) — preferred
OPENAI_API_KEY=                                 # Alternative: OpenAI text-embedding-3-small

# ── Monitoring (Pflicht) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Social Media APIs (Phase 4+) ─────────────────────────
TWITTER_BEARER_TOKEN=                           # X/Twitter API v2
YOUTUBE_API_KEY=                                # YouTube Data API v3

# ── Revenue Tools (Phase 6+) ─────────────────────────────
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
GUMROAD_ACCESS_TOKEN=

# ── Crypto Data (Free Tiers reichen für MVP) ─────────────
COINGECKO_API_KEY=                              # Optional, Free Tier braucht keinen Key
GLASSNODE_API_KEY=                              # Free Tier: limited endpoints

# ── Exchange APIs (Sprint 3 — eigenes Trading) ───────────
# BINANCE_API_KEY=
# BINANCE_SECRET=
# BITGET_API_KEY=
# BITGET_SECRET=

# ── System ────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development                         # development | staging | production
